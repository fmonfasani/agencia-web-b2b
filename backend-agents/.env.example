DATABASE_URL = postgresql://postgres:password@localhost:5432/agencia_web_b2b
ALLOWED_ORIGINS = http://localhost:3001,http://127.0.0.1:3001
OLLAMA_BASE_URL = http://localhost:11434
DEFAULT_MODEL = gemma3:latest
ALLOW_FALLBACK_TENANT = false
DEFAULT_TENANT_ID = default
LOG_LEVEL = INFO

# OpenRouter (opcional - para usar LLMs en la nube)
OPENROUTER_API_KEYS = sk-or-v1-xxx,sk-or-v1-yyy
OPENROUTER_DEFAULT_MODEL = openai/gpt-3.5-turbo
OPENROUTER_STRATEGY = least_used
OPENROUTER_MAX_DAILY_PER_KEY = 45
OPENROUTER_APP_NAME = Backend-Agents
OPENROUTER_APP_URL = https://tusitio.com

