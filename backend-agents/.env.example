# Database (Desarrollo = agencia_web_b2b_dev)
DATABASE_URL=postgresql://postgres:Karaoke27570Echeverria@postgres:5432/agencia_web_b2b_dev

# CORS (Development)
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# LLM Configuration
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_MODEL=qwen2.5:3b
ALLOW_FALLBACK_TENANT=false
DEFAULT_TENANT_ID=default

# Logging
LOG_LEVEL=INFO

# OpenRouter (opcional - para usar LLMs en la nube)
OPENROUTER_API_KEYS=
OPENROUTER_DEFAULT_MODEL=openai/gpt-3.5-turbo
OPENROUTER_STRATEGY=least_used
OPENROUTER_MAX_DAILY_PER_KEY=45

