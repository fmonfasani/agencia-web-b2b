# ========================================
# BACKEND AGENTS - .env.example
# COPY TO .env FOR DEVELOPMENT
# NEVER COMMIT ACTUAL .env FILES
# ========================================

# ── Database (REQUIRED — service won't start without this) ───────────────────
# Local dev:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/agencia_web_b2b
# Docker Compose (use service name):
# DATABASE_URL=postgresql://postgres:yourpassword@postgres:5432/agencia_web_b2b

# ── LLM provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama   # ollama | openrouter

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
# Docker: OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenRouter (cloud — optional)
OPENROUTER_API_KEYS=
OPENROUTER_DEFAULT_MODEL=openai/gpt-3.5-turbo
OPENROUTER_STRATEGY=least_used
OPENROUTER_MAX_DAILY_PER_KEY=45

# ── Vector DB (REQUIRED for RAG) ──────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# Docker: QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001

# ── Multi-tenant ─────────────────────────────────────────────────────────────
ALLOW_FALLBACK_TENANT=false
DEFAULT_TENANT_ID=default

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

