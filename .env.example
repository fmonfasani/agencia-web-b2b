# ============================================
# AGENCIA B2B - Environment Variables
# ============================================
# ⚠️ IMPORTANT: Remove all fallbacks in production!
# Copy this file to .env and fill in all values

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ============================================
# NEXT.JS AUTH (REQUIRED - NO FALLBACK!)
# ============================================
AUTH_SECRET=                    # Generate with: openssl rand -base64 32
NEXTAUTH_URL=https://tu-dominio.com
AUTH_TRUST_HOST=true

# ============================================
# INTERNAL API (REQUIRED - NO FALLBACK!)
# ============================================
INTERNAL_API_SECRET=           # Generate with: openssl rand -hex 32
ADMIN_SECRET=

# ============================================
# OAUTH PROVIDERS
# ============================================
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# ============================================
# RATE LIMITING (Upstash Redis)
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# AGENT SERVICE (FastAPI)
# ============================================
AGENT_SERVICE_URL=http://localhost:8000

# ============================================
# SECURE API BRIDGE
# ============================================
BRIDGE_API_KEY=
NEXTJS_INTERNAL_AUTH_URL=https://tu-dominio.com/api/auth/internal
BRIDGE_URL=

# ============================================
# SENTRY
# ============================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ============================================
# AI SERVICES
# ============================================
OPENAI_API_KEY=
ASSISTANT_ID=
