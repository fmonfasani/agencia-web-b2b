# === LLM Provider ===
LLM_PROVIDER=groq
GROQ_API_KEY=tu_groq_api_key_aqui
GROQ_MODEL=llama-3.1-8b-instant

# === Database ===
DATABASE_URL=postgresql://user:password@localhost:5432/agencia_b2b

# === Auth ===
ADMIN_SECRET=$Karaoke27570Echeverria

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000,https://tu-dominio.com

# =====================================================
# === SCRAPER (Google Maps via Apify) ================
# =====================================================
# 1. Creá una cuenta gratuita en https://apify.com
# 2. Andá a Settings > Integrations > API tokens
# 3. Copiá tu token y pegalo acá
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxx

# URL base de tu app Next.js (sin trailing slash)
# En local: http://localhost:3000
# En producción: https://agencia-web-b2b.vercel.app
NEXTJS_INTERNAL_URL=http://localhost:3000

# Secret compartido para que el agent-service pueda llamar
# al endpoint /api/leads/ingest de Next.js sin que Next.js lo rechace.
# Genera uno aleatorio: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_SECRET=genera_un_secret_aleatorio_aqui
