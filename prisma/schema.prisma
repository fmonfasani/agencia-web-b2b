// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                       String            @id @default(cuid())
  email                    String            @unique
  name                     String?
  firstName                String?
  lastName                 String?
  image                    String?
  whatsapp                 String?
  emailVerified            DateTime?
  passwordHash             String?
  status                   String            @default("ACTIVE") // ACTIVE, INACTIVE, BLOCKED, DELETED
  lastLoginAt              DateTime?
  deletedAt                DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  memberships              Membership[]
  passwordResetTokens      PasswordResetToken[]
  invitationsSent          Invitation[]      @relation("InvitationInvitedBy")
  invitationsAccepted      Invitation[]      @relation("InvitationAcceptedBy")
  invitationsAcceptedAudit InvitationAudit[] @relation("AuditAcceptedBy")
  invitationsSentAudit     InvitationAudit[] @relation("AuditInvitedBy")
  sessions                 Session[]
  accounts                 Account[]
  auditEvents              AuditEvent[]
  activities               Activity[]
  tasks                    Task[]
  dailyMetrics             UserDailyMetrics[]
  deals                    Deal[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Custom fields kept for app logic
  tenantId     String?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
}

model AuditEvent {
  id        String   @id @default(cuid())
  eventType String
  userId    String?
  tenantId  String?
  ipAddress String?
  metadata  Json
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([createdAt])
  @@index([tenantId])
}

model Tenant {
  id               String            @id @default(cuid())
  name             String
  slug             String?           @unique
  website          String?
  whatsapp         String?
  status           String            @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED
  onboardingDone   Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  memberships      Membership[]
  invitations      Invitation[]
  invitationAudits InvitationAudit[]
  subscription     Subscription?
  agents           Agent[]
  products         Product[]
  services         Service[]
  pipelines        Pipeline[]
  customers        Customer[]
  deals            Deal[]
  businessEvents   BusinessEvent[]
  activities       Activity[]
  tasks            Task[]
  projects         Project[]
  userDailyMetrics UserDailyMetrics[]
  apiCostEvents    ApiCostEvent[]
  businessMetrics  BusinessMetric[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  code          String         @unique // e.g., 'BASIC', 'PRO', 'ENTERPRISE'
  description   String?
  price         Decimal
  limits        Json           // { maxUsers: 10, maxLeads: 1000, ... }
  features      String[]       // List of enabled tags
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
}

model Subscription {
  id                  String    @id @default(cuid())
  tenantId            String    @unique
  planId              String
  status              String    @default("ACTIVE") // ACTIVE, PAST_DUE, CANCELED
  currentPeriodStart  DateTime  @default(now())
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                Plan      @relation(fields: [planId], references: [id])
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  role       Role     @default(MEMBER)
  department String?  // e.g., 'SALES', 'DEVELOPER'
  status     String   @default("ACTIVE") // ACTIVE, INACTIVE, BLOCKED
  acceptedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([role])
}

model Invitation {
  id           String            @id @default(cuid())
  email        String
  tenantId     String
  role         Role
  tokenHash    String            @unique
  expiresAt    DateTime
  invitedById  String
  acceptedById String?
  invitedAt    DateTime          @default(now())
  acceptedAt   DateTime?
  status       String            @default("PENDING")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy    User              @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy   User?             @relation("InvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)
  auditLogs    InvitationAudit[]

  @@index([email, tenantId])
  @@index([status])
  @@index([expiresAt])
}

model InvitationAudit {
  id           String     @id @default(cuid())
  invitationId String
  tenantId     String
  invitedById  String
  acceptedById String?
  invitedEmail String
  role         Role
  invitedAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime   @default(now())
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy    User       @relation("AuditInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy   User?      @relation("AuditAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([tenantId, invitedAt])
}

// Lead model for contact form submissions
enum LeadSourceType {
  SCRAPER
  MANUAL
  API
  ADS
}

enum BusinessType {
  SERVICIO
  INDUSTRIA
  COMERCIO
  OFICIO
}

// Lead model for structured acquisition and intelligent classification
model Lead {
  id               String         @id @default(cuid())
  tenantId         String
  sourceType       LeadSourceType @default(MANUAL)
  businessType     BusinessType?  // Validated at app level for manual entries
  
  // Basic Info (Normalized)
  email            String?
  name             String?        // Full name
  firstName        String?
  lastName         String?
  companyName      String?
  phone            String?
  whatsapp         String?
  
  // Social & Web
  website          String?
  instagram        String?
  facebook         String?
  tiktok           String?
  linkedin         String?
  deals            Deal[]

  // Flags de Verificación Manual / Auto
  isEmailCorp      Boolean        @default(false)
  isWebFunctional  Boolean        @default(true)
  
  // Scraper / Google Maps Data
  googlePlaceId    String?        @unique
  googleMapsUrl    String?
  category         String?        // Original Maps category
  rating           Float?
  reviewsCount     Int?
  address          String?
  hasPhysicalLocal Boolean        @default(false)
  
  // Enrichment & IA Results
  description      String?        @db.Text
  topKeywords      String[]       // Frequency extraction
  budget           String?
  message          String?
  
  // Scoring & Status
  status           String         @default("NEW") // NEW, CONTACTED, QUALIFIED, PROPOSAL_SENT, CONVERTED, LOST, DISQUALIFIED
  source           String         @default("manual") // Legacy compatibility
  potentialScore   Float          @default(0) // 0-100 calculation
  completeness     Float          @default(0) // 0-1 percentage
  priority         String         @default("LOW") // LOW, MEDIUM, HIGH
  
  // Metadata for original input traceability
  rawMetadata      Json?
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Lead Intelligence (1:1)
  intelligence     LeadIntelligence?

  @@index([tenantId])
  @@index([tenantId, sourceType, status])
  @@index([potentialScore])
  @@index([email])
  @@index([status])
  @@index([createdAt])
}

// Newsletter subscription model
model Newsletter {
  id             String    @id @default(cuid())
  email          String    @unique
  status         String    @default("ACTIVE") // ACTIVE, UNSUBSCRIBED
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@index([email])
  @@index([status])
}

// --- REVENUE OS: TEAM PERFORMANCE EXTENSION ---

model Activity {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  type      String   // CALL, LEAD_CONTACT, CODE_COMMIT, TICKET_RESOLVED
  impact    Float?   // Puntuación de impacto estimada
  metadata  Json?    // Detalles específicos (ej: duración de llamada)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String?
  projectId   String?
  title       String
  status      String    // TODO, IN_PROGRESS, DONE, BLOCKED
  priority    String    // LOW, MEDIUM, HIGH, CRITICAL
  estimatedHours Float?
  actualHours   Float?
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User?     @relation(fields: [userId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Project {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  status    String
  value     Decimal?  // Valor del proyecto para el revenue
  tasks     Task[]
  createdAt DateTime  @default(now())
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model UserDailyMetrics {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String
  date            DateTime @default(now())
  callsCount      Int      @default(0)
  tasksCompleted  Int      @default(0)
  revenueGenerated Decimal  @default(0)
  workloadPercent Float    @default(0)
  impactScore     Float    @default(0)

  user            User     @relation(fields: [userId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, date])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
  VIEWER
}

// ============================================================
// SAAS B2B MULTI-TENANT EXTENSION
// ============================================================

enum AgentType {
  INFORMATIVO
  COMERCIAL
  SOPORTE
}

enum AgentChannel {
  WHATSAPP
  WEB
  EMAIL
}

enum DealStage {
  PROSPECTING
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

// AI or Automated Seller Agent (no human login)
model Agent {
  id           String   @id @default(cuid())
  tenantId     String?
  name         String
  description  String?
  systemPrompt String   @map("system_prompt") @db.Text
  config       Json     @default("{}")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Fields for the original CRM app (optional compatibility or migration)
  type         AgentType?    @default(COMERCIAL)
  channel      AgentChannel? @default(WEB)
  assistantId  String?      // OpenAI Assistant ID
  promptConfig String?      @db.Text
  knowledgeBase String?     @db.Text

  tenant       Tenant?          @relation(fields: [tenantId], references: [id])
  apiKeys      AgentApiKey[]
  conversations Conversation[]
  deals        Deal[]

  @@map("agents")
  @@index([tenantId])
}

model AgentApiKey {
  id          String    @id @default(cuid())
  agentId     String
  keyHash     String    @unique @map("key_hash")   // SHA-256 del key real
  label       String                               // ej: "cliente-a.com"
  active      Boolean   @default(true)
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  agent       Agent     @relation(fields: [agentId], references: [id])

  @@map("agent_api_keys")
}

model Conversation {
  id        String    @id @default(cuid())
  agentId   String
  sessionId String    @map("session_id")   // generado en el cliente (UUID)
  messages  Json      @default("[]")       // array de {role, content}
  metadata  Json      @default("{}")       // IP, referrer, etc
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  agent     Agent     @relation(fields: [agentId], references: [id])

  @@index([agentId, sessionId])
  @@map("conversations")
}

// Multi-product support per tenant
model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?  @db.Text
  price       Decimal?
  currency    String   @default("ARS")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deals       Deal[]

  @@index([tenantId])
}

// Multi-service support per tenant
model Service {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?  @db.Text
  price       Decimal?
  currency    String   @default("ARS")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Sales pipeline configuration per tenant
model Pipeline {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deals     Deal[]

  @@index([tenantId])
}

// Individual sales opportunity
model Deal {
  id                 String    @id @default(cuid())
  tenantId           String
  leadId             String?
  pipelineId         String?
  productId          String?
  assignedToUserId   String?   // Human seller
  assignedToAgentId  String?   // AI agent
  stage              DealStage @default(PROSPECTING)
  value              Decimal?
  currency           String    @default("ARS")
  notes              String?   @db.Text
  closedAt           DateTime?
  expectedCloseDate  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedToUser     User?     @relation(fields: [assignedToUserId], references: [id])
  assignedToAgent    Agent?    @relation(fields: [assignedToAgentId], references: [id])
  pipeline           Pipeline? @relation(fields: [pipelineId], references: [id])
  product            Product?  @relation(fields: [productId], references: [id])
  lead               Lead?     @relation(fields: [leadId], references: [id])

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([assignedToUserId])
  @@index([assignedToAgentId])
}

// Converted customers (from leads)
model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  email       String?
  name        String?
  company     String?
  phone       String?
  whatsapp    String?
  leadId      String?  // Original lead reference
  mrr         Decimal  @default(0) // Monthly recurring revenue from this customer
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, email])
}

// Event Bus log for event-driven architecture
model BusinessEvent {
  id        String   @id @default(cuid())
  tenantId  String?
  type      String   // TENANT_CREATED, LEAD_CREATED, DEAL_CLOSED, AGENT_MESSAGE_SENT, etc.
  payload   Json     @default("{}")
  source    String?  // "api", "agent", "human", "system"
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
}

// Lead Intelligence Engine — análisis digital + scoring + outreach AI
model LeadIntelligence {
  id                  String   @id @default(cuid())
  leadId              String   @unique

  // Tier classification
  tier                String   @default("COLD") // HOT | WARM | COOL | COLD
  opportunityScore    Int      @default(0)       // 0-100 final
  demandScore         Int      @default(0)       // rating + reviews
  digitalGapScore     Int      @default(0)       // brecha digital
  outreachScore       Int      @default(0)       // canales disponibles

  // Website analysis (sin Playwright — HTTP checks)
  websiteLoads        Boolean?
  hasSSL              Boolean?
  hasContactForm      Boolean?
  hasBookingSystem    Boolean?
  hasChatbot          Boolean?
  hasWhatsappLink     Boolean?
  responseTimeMs      Int?     // latencia en ms

  // Detected problems (array de objetos {key, problem, service, urgency})
  detectedProblems    Json     @default("[]")
  topProblem          String?  // problema más urgente
  revenueEstimate     Int?     // USD/mes estimado de oportunidad

  // Channel intelligence
  bestChannel         String?  // whatsapp | email | instagram | linkedin
  channelScores       Json     @default("{}")

  // AI outreach messages
  whatsappMsg         String?  @db.Text
  emailSubject        String?
  emailBody           String?  @db.Text

  // Meta
  modelVersion        String   @default("1.0")
  analyzedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  lead                Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@index([opportunityScore])
  @@index([analyzedAt])
}

model ApiCostEvent {
  id             String   @id @default(cuid())
  tenantId       String
  api            String   // "openai" | "google_places"
  endpoint       String
  model          String?  // only for OpenAI
  tokensInput    Int?
  tokensOutput   Int?
  responseCount  Int?
  costUsd        Float
  timestamp      DateTime @default(now())
  createdAt      DateTime @default(now())

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, api, timestamp])
}

model BusinessMetric {
  id        String   @id @default(cuid())
  tenantId  String
  type      String   // "EXTRACTION_SUCCESS", "EXTRACTION_LATENCY"
  status    String   // "SUCCESS", "FAILURE"
  value     Float?
  metadata  Json?
  timestamp DateTime @default(now())
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([timestamp])
}

model VpsMetric {
  id        String   @id @default(cuid())
  cpuUsage  Float
  memUsage  Float
  diskUsage Float
  netIn     Float?   // Inbound bytes/s
  netOut    Float?   // Outbound bytes/s
  timestamp DateTime @default(now())

  @@index([timestamp])
}

model Trace {
  id        String   @id @default(cuid())
  traceId   String
  service   String
  operation String
  duration  Int
  status    String
  createdAt DateTime @default(now())

  @@index([traceId])
  @@index([service])
  @@index([createdAt])
}

model Metric {
  id        String   @id @default(cuid())
  name      String
  value     Float
  tags      Json?
  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
}

model LogEntry {
  id        String   @id @default(cuid())
  level     String
  message   String
  traceId   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([traceId])
  @@index([createdAt])
}

model Audit {
  id                String    @id @default(cuid())
  repositoryUrl     String
  status            String    @default("pending")
  overallScore      Float?
  architectureScore Float?
  securityScore     Float?
  codeQualityScore  Float?
  devopsScore       Float?
  summary           String?   @db.Text
  createdAt         DateTime  @default(now())

  findings Finding[]
}

model Finding {
  id             String @id @default(cuid())
  auditId        String
  audit          Audit  @relation(fields: [auditId], references: [id])

  severity       String
  category       String
  file           String?
  line           Int?
  message        String @db.Text
  recommendation String @db.Text
}
