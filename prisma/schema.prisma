generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                       String               @id @default(cuid())
  email                    String               @unique
  name                     String?
  firstName                String?
  lastName                 String?
  image                    String?
  whatsapp                 String?
  emailVerified            DateTime?
  passwordHash             String?
  status                   String               @default("ACTIVE")
  lastLoginAt              DateTime?
  deletedAt                DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  accounts                 Account[]
  activities               Activity[]
  auditEvents              AuditEvent[]
  deals                    Deal[]
  invitationsAccepted      Invitation[]         @relation("InvitationAcceptedBy")
  invitationsSent          Invitation[]         @relation("InvitationInvitedBy")
  invitationsAcceptedAudit InvitationAudit[]    @relation("AuditAcceptedBy")
  invitationsSentAudit     InvitationAudit[]    @relation("AuditInvitedBy")
  memberships              Membership[]
  passwordResetTokens      PasswordResetToken[]
  sessions                 Session[]
  tasks                    Task[]
  dailyMetrics             UserDailyMetrics[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String    @id @default(cuid())
  sessionToken String    @unique
  userId       String
  expires      DateTime
  tenantId     String?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id        String         @id @default(cuid())
  eventType AuditEventType
  userId    String?
  tenantId  String?
  ipAddress String?
  metadata  Json
  createdAt DateTime       @default(now())
  user      User?          @relation(fields: [userId], references: [id])

  @@index([eventType])
  @@index([createdAt])
  @@index([tenantId])
}

model Tenant {
  id                String             @id @default(cuid())
  name              String
  slug              String?            @unique
  website           String?
  whatsapp          String?
  status            String             @default("ACTIVE")
  onboardingDone    Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  branding          Json?
  activities        Activity[]
  apiCostEvents     ApiCostEvent[]
  businessEvents    BusinessEvent[]
  businessMetrics   BusinessMetric[]
  customers         Customer[]
  deals             Deal[]
  invitations       Invitation[]
  invitationAudits  InvitationAudit[]
  memberships       Membership[]
  outreachCampaigns OutreachCampaign[]
  pipelines         Pipeline[]
  products          Product[]
  projects          Project[]
  services          Service[]
  subscription      Subscription?
  tasks             Task[]
  userDailyMetrics  UserDailyMetrics[]
  agents            Agent[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  code          String         @unique
  description   String?
  price         Decimal
  limits        Json
  features      String[]
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
}

model Subscription {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  planId             String
  status             String   @default("ACTIVE")
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  plan               Plan     @relation(fields: [planId], references: [id])
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  department String?
  status     String   @default("ACTIVE")
  acceptedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  role       Role     @default(MEMBER)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([role])
}

model Invitation {
  id           String            @id @default(cuid())
  email        String
  tenantId     String
  tokenHash    String            @unique
  expiresAt    DateTime
  invitedById  String
  acceptedById String?
  invitedAt    DateTime          @default(now())
  acceptedAt   DateTime?
  status       String            @default("PENDING")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  role         Role
  acceptedBy   User?             @relation("InvitationAcceptedBy", fields: [acceptedById], references: [id])
  invitedBy    User              @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs    InvitationAudit[]

  @@index([email, tenantId])
  @@index([status])
  @@index([expiresAt])
}

model InvitationAudit {
  id           String     @id @default(cuid())
  invitationId String
  tenantId     String
  invitedById  String
  acceptedById String?
  invitedEmail String
  invitedAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime   @default(now())
  role         Role
  acceptedBy   User?      @relation("AuditAcceptedBy", fields: [acceptedById], references: [id])
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  invitedBy    User       @relation("AuditInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, invitedAt])
}

model Lead {
  id                   String            @id @default(cuid())
  tenantId             String
  sourceType           LeadSourceType    @default(MANUAL)
  businessType         BusinessType?
  email                String?
  name                 String?
  firstName            String?
  lastName             String?
  companyName          String?
  phone                String?
  whatsapp             String?
  website              String?
  instagram            String?
  facebook             String?
  tiktok               String?
  linkedin             String?
  isEmailCorp          Boolean           @default(false)
  isWebFunctional      Boolean           @default(true)
  googlePlaceId        String?           @unique
  googleMapsUrl        String?
  category             String?
  rating               Float?
  reviewsCount         Int?
  address              String?
  hasPhysicalLocal     Boolean           @default(false)
  description          String?
  topKeywords          String[]
  budget               String?
  message              String?
  status               String            @default("NEW")
  source               String            @default("manual")
  potentialScore       Float             @default(0)
  completeness         Float             @default(0)
  priority             String            @default("LOW")
  rawMetadata          Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  websiteScore         Int?
  socialPresence       Json?
  designQuality        String?
  estimatedCompanySize String?
  lastEnriched         DateTime?
  enrichmentStatus     String?
  industry             String?
  pipelineStatus       PipelineStatus    @default(NUEVO)
  score                Int?
  scoreReason          String?
  recommendedService   String?
  urgency              String?
  estimatedBudget      String?
  bestTimeToCall       String?
  brief                String?
  technologies         String[]          @default([])
  hasAnalytics         Boolean?
  hasPixel             Boolean?
  hasSEO               Boolean?
  isResponsive         Boolean?
  websiteAge           String?
  companySize          String?
  mainProducts         String[]          @default([])
  competitors          Json?
  lastEnrichedAt       DateTime?
  appointments         Appointment[]
  deals                Deal[]
  intelligence         LeadIntelligence?
  outreachMessages     OutreachMessage[]
  proposal             Proposal?

  @@unique([tenantId, website])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, sourceType, status])
  @@index([potentialScore])
  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Newsletter {
  id             String    @id @default(cuid())
  email          String    @unique
  status         String    @default("ACTIVE")
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@index([email])
  @@index([status])
}

model Activity {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  type      String
  impact    Float?
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Task {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String?
  projectId      String?
  title          String
  status         String
  priority       String
  estimatedHours Float?
  actualHours    Float?
  dueAt          DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project?  @relation(fields: [projectId], references: [id])
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?     @relation(fields: [userId], references: [id])
}

model Project {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  status    String
  value     Decimal?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model UserDailyMetrics {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String
  date             DateTime @default(now())
  callsCount       Int      @default(0)
  tasksCompleted   Int      @default(0)
  revenueGenerated Decimal  @default(0)
  workloadPercent  Float    @default(0)
  impactScore      Float    @default(0)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId, date])
}

model Agent {
  id            String         @id @default(cuid())
  tenantId      String?
  name          String
  description   String?
  systemPrompt  String         @map("system_prompt")
  config        Json           @default("{}")
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  type          AgentType?     @default(COMERCIAL)
  channel       AgentChannel?  @default(WEB)
  assistantId   String?
  promptConfig  String?
  knowledgeBase String?
  deals         Deal[]
  apiKeys       AgentApiKey[]
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  conversations Conversation[]

  @@index([tenantId])
  @@map("agents")
}

model AgentApiKey {
  id         String    @id @default(cuid())
  agentId    String
  keyHash    String    @unique @map("key_hash")
  label      String
  active     Boolean   @default(true)
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  agent      Agent     @relation(fields: [agentId], references: [id])

  @@map("agent_api_keys")
}

model Conversation {
  id        String   @id @default(cuid())
  agentId   String
  sessionId String   @map("session_id")
  messages  Json     @default("[]")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  agent     Agent    @relation(fields: [agentId], references: [id])

  @@index([agentId, sessionId])
  @@map("conversations")
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  price       Decimal?
  currency    String   @default("ARS")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deals       Deal[]
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Service {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  price       Decimal?
  currency    String   @default("ARS")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Pipeline {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  deals     Deal[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Deal {
  id                String    @id @default(cuid())
  tenantId          String
  leadId            String?
  pipelineId        String?
  productId         String?
  assignedToUserId  String?
  assignedToAgentId String?
  stage             DealStage @default(PROSPECTING)
  value             Decimal?
  currency          String    @default("ARS")
  notes             String?
  closedAt          DateTime?
  expectedCloseDate DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  assignedToAgent   Agent?    @relation(fields: [assignedToAgentId], references: [id])
  assignedToUser    User?     @relation(fields: [assignedToUserId], references: [id])
  lead              Lead?     @relation(fields: [leadId], references: [id])
  pipeline          Pipeline? @relation(fields: [pipelineId], references: [id])
  product           Product?  @relation(fields: [productId], references: [id])
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([assignedToUserId])
  @@index([assignedToAgentId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  email     String?
  name      String?
  company   String?
  phone     String?
  whatsapp  String?
  leadId    String?
  mrr       Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, email])
}

model BusinessEvent {
  id        String   @id @default(cuid())
  tenantId  String?
  type      String
  payload   Json     @default("{}")
  source    String?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
}

model LeadIntelligence {
  id               String   @id @default(cuid())
  leadId           String   @unique
  tier             String   @default("COLD")
  opportunityScore Int      @default(0)
  demandScore      Int      @default(0)
  digitalGapScore  Int      @default(0)
  outreachScore    Int      @default(0)
  websiteLoads     Boolean?
  hasSSL           Boolean?
  hasContactForm   Boolean?
  hasBookingSystem Boolean?
  hasChatbot       Boolean?
  hasWhatsappLink  Boolean?
  responseTimeMs   Int?
  detectedProblems Json     @default("[]")
  topProblem       String?
  revenueEstimate  Int?
  bestChannel      String?
  channelScores    Json     @default("{}")
  whatsappMsg      String?
  emailSubject     String?
  emailBody        String?
  modelVersion     String   @default("1.0")
  analyzedAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt
  enrichmentData   Json?
  strategicBrief   String?
  marketAnalysis   String?
  nicheAnalysis    String?
  interviewGuide   String?
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@index([opportunityScore])
  @@index([analyzedAt])
}

model ApiCostEvent {
  id            String   @id @default(cuid())
  tenantId      String
  api           String
  endpoint      String
  model         String?
  tokensInput   Int?
  tokensOutput  Int?
  responseCount Int?
  costUsd       Float
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, api, timestamp])
}

model BusinessMetric {
  id        String   @id @default(cuid())
  tenantId  String
  type      String
  status    String
  value     Float?
  metadata  Json?
  timestamp DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([timestamp])
}

model VpsMetric {
  id        String   @id @default(cuid())
  cpuUsage  Float
  memUsage  Float
  diskUsage Float
  netIn     Float?
  netOut    Float?
  timestamp DateTime @default(now())

  @@index([timestamp])
}

model Trace {
  id        String   @id @default(cuid())
  traceId   String
  service   String
  operation String
  duration  Int
  status    String
  createdAt DateTime @default(now())

  @@index([traceId])
  @@index([service])
  @@index([createdAt])
}

model Metric {
  id        String   @id @default(cuid())
  name      String
  value     Float
  tags      Json?
  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
}

model LogEntry {
  id        String   @id @default(cuid())
  level     String
  message   String
  traceId   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([traceId])
  @@index([createdAt])
}

model Audit {
  id                String    @id @default(cuid())
  repositoryUrl     String
  status            String    @default("pending")
  overallScore      Float?
  architectureScore Float?
  securityScore     Float?
  codeQualityScore  Float?
  devopsScore       Float?
  summary           String?
  createdAt         DateTime  @default(now())
  findings          Finding[]
}

model Finding {
  id             String  @id @default(cuid())
  auditId        String
  severity       String
  category       String
  file           String?
  line           Int?
  message        String
  recommendation String
  audit          Audit   @relation(fields: [auditId], references: [id])
}

model RumEvent {
  id        String   @id @default(uuid())
  sessionId String
  userId    String?
  page      String
  metric    String
  value     Float
  userAgent String?
  createdAt DateTime @default(now())

  @@index([page, metric, createdAt])
}

model OperationEvent {
  id        String   @id @default(uuid())
  location  String?
  industry  String?
  provider  String
  operation String
  success   Boolean
  latencyMs Int
  errorCode String?
  createdAt DateTime @default(now())

  @@index([provider, createdAt])
  @@index([location, industry])
}

model BudgetConfig {
  id       String @id @default(uuid())
  provider String @unique
  monthly  Float
  warning  Float  @default(0.8)
  critical Float  @default(0.95)
}

model OutreachCampaign {
  id        String            @id @default(cuid())
  tenantId  String
  name      String
  channel   String
  status    String            @default("DRAFT")
  template  String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages  OutreachMessage[]

  @@index([tenantId])
}

model OutreachMessage {
  id          String           @id @default(cuid())
  campaignId  String
  leadId      String
  status      String           @default("PENDING")
  content     String
  error       String?
  externalId  String?
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  campaign    OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([leadId])
  @@index([status])
}

model ScraperSchedule {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String
  query            String
  location         String
  maxLeads         Int       @default(50) @map("max_leads")
  provider         String    @default("google")
  frequencyMinutes Int?      @map("frequency_minutes")
  specificTime     DateTime? @map("specific_time") @db.Time(6)
  is_active        Boolean   @default(true)
  last_run         DateTime? @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenant_id], map: "idx_scraper_schedules_tenant")
  @@map("scraper_schedules")
}

model Appointment {
  id          String            @id @default(cuid())
  leadId      String
  tenantId    String
  scheduledAt DateTime
  duration    Int               @default(30)
  type        AppointmentType   @default(CALL)
  status      AppointmentStatus @default(PENDING)
  notes       String?
  outcome     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  lead        Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, scheduledAt])
  @@index([leadId])
}

model scraper_jobs {
  id             String    @id
  tenant_id      String
  query          String
  location       String
  max_leads      Int
  provider       String
  source         String    @default("manual")
  schedule_id    String?
  status         String
  leads_found    Int       @default(0)
  leads_ingested Int       @default(0)
  errors         Json      @default("[]")
  message        String    @default("")
  apify_run_id   String?
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)
  completed_at   DateTime? @db.Timestamptz(6)

  @@index([tenant_id, created_at(sort: Desc)], map: "idx_scraper_jobs_tenant_created_at")
}

enum AuditEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  TENANT_SWITCH
  TENANT_SWITCH_DENIED
  UNAUTHORIZED_ACCESS
  ADMIN_ACTION
  PASSWORD_CHANGED
  INVITATION_SENT
  INVITATION_ACCEPTED
  COMPANY_REGISTERED
  ONBOARDING_COMPLETED
  LEAD_CREATED
  DEAL_UPDATED
  API_QUERY
  SYSTEM_STATUS_CHANGE
}

enum LeadSourceType {
  SCRAPER
  MANUAL
  API
  ADS
}

enum BusinessType {
  SERVICIO
  INDUSTRIA
  COMERCIO
  OFICIO
}

enum PipelineStatus {
  NUEVO
  ENRIQUECIDO
  SCORED
  INVESTIGADO
  CITADO
  LLAMADO
  PROPUESTA_ENVIADA
  CERRADO_GANADO
  CERRADO_PERDIDO
  DESCARTADO
}

enum AppointmentType {
  CALL
  VIDEO_CALL
  IN_PERSON
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  NO_SHOW
  RESCHEDULED
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
  VIEWER
}

enum AgentType {
  INFORMATIVO
  COMERCIAL
  SOPORTE
}

enum AgentChannel {
  WHATSAPP
  WEB
  EMAIL
}

enum DealStage {
  PROSPECTING
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

model Proposal {
  id           String         @id @default(cuid())
  leadId       String         @unique
  tenantId     String
  title        String
  problem      String
  solution     String
  deliverables Json
  timeline     String
  investment   String
  roi          String?
  content      String         @db.Text
  slug         String         @unique
  viewedAt     DateTime?
  viewCount    Int            @default(0)
  sentAt       DateTime?
  status       ProposalStatus @default(DRAFT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}
