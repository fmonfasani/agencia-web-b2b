# ========================================
# BACKEND SAAS - .env.example
# COPY TO .env FOR DEVELOPMENT
# NEVER COMMIT ACTUAL .env FILES
# ========================================

# ── Database (REQUIRED — service won't start without this) ───────────────────
# Local dev:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/agencia_web_b2b
# Docker Compose (use service name):
# DATABASE_URL=postgresql://postgres:yourpassword@postgres:5432/agencia_web_b2b

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development   # development | staging | production

# ── Backend Services ─────────────────────────────────────────────────────────
# Local dev:
BACKEND_AGENTS_URL=http://localhost:8001
# Docker Compose:
# BACKEND_AGENTS_URL=http://backend-agents:8001

QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET=changeme-at-least-32-chars-long

# ── Connection pool ───────────────────────────────────────────────────────────
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Timeouts (seconds) ────────────────────────────────────────────────────────
TIMEOUT_AGENT_S=60
TIMEOUT_DB_S=5
TIMEOUT_REDIS_S=1

# ── Usage worker ─────────────────────────────────────────────────────────────
USAGE_WORKER_BATCH_SIZE=50
USAGE_WORKER_SLEEP_S=0.1

# ── Quota reconciliation ─────────────────────────────────────────────────────
RECONCILE_INTERVAL_S=300
CLEANUP_INTERVAL_S=60
QUOTA_DRIFT_THRESHOLD=50

# ── Multi-tenant ─────────────────────────────────────────────────────────────
ALLOW_FALLBACK_TENANT=false
DEFAULT_TENANT_ID=default

# ── AI / LLM ─────────────────────────────────────────────────────────────────
LLM_MODEL=qwen2.5:0.5b
EMBED_MODEL=nomic-embed-text

# ── Optional ─────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# REDIS_URL=redis://localhost:6379/0
