# ========================================
# BACKEND SAAS - PRODUCTION TEMPLATE
# COPY TO .env.production AND FILL IN VALUES
# NEVER COMMIT .env.production
# ========================================

# Database (Producción = agencia_web_b2b_prod)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_USER=postgres
POSTGRES_HOST=prod-db.aws.com
POSTGRES_PORT=5432
POSTGRES_DB=agencia_web_b2b_prod

# Backend Services (internal Docker network or remote)
BACKEND_AGENTS_URL=http://backend-agents:8001
QDRANT_URL=http://qdrant:6333
OLLAMA_URL=http://ollama:11434

# CORS (Production)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,https://admin.yourdomain.com

# Logging
LOG_LEVEL=WARNING
ENVIRONMENT=production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
